{
  "entities": {
    "User": {
      "title": "User",
      "description": "Student profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Course": {
      "title": "Course",
      "description": "Enrolled courses for the semester",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "code": { "type": "string" },
        "instructor": { "type": "string" },
        "color": { "type": "string" },
        "schedule": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "color"]
    },
    "Task": {
      "title": "Task",
      "description": "Specific assignments, study sessions, or exams",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "subTasks": {
          "type": "array",
          "items": { "type": "object" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "dueDate", "status"]
    },
    "StudySession": {
      "title": "Study Session",
      "description": "Logged focus time",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "duration": { "type": "integer", "description": "Duration in minutes" },
        "startTime": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["userId", "duration", "startTime"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course information"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Assignment and task data"
    },
    "/studySessions/{sessionId}": {
      "schema": "StudySession",
      "description": "Focus time logs"
    }
  }
}
